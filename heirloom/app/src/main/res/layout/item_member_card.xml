<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="96dp"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:layout_marginEnd="12dp">

    <com.google.android.material.card.MaterialCardView
        android:layout_width="96dp"
        android:layout_height="wrap_content"
        app:cardBackgroundColor="@color/heirloom_surface"
        app:cardCornerRadius="18dp"
        app:cardElevation="0dp"
        app:strokeColor="@color/heirloom_border"
        app:strokeWidth="1dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:padding="14dp">

            <!-- Avatar -->
            <FrameLayout
                android:layout_width="52dp"
                android:layout_height="52dp">

                <ImageView
                    android:id="@+id/iv_member_avatar"
                    android:layout_width="52dp"
                    android:layout_height="52dp"
                    android:scaleType="centerCrop"
                    android:background="@drawable/bg_avatar_circle"
                    android:contentDescription="@null" />

                <TextView
                    android:id="@+id/tv_member_initial"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:textSize="21sp"
                    android:textColor="@color/white"
                    android:textStyle="bold" />

            </FrameLayout>

            <!-- Name -->
            <TextView
                android:id="@+id/tv_member_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="9dp"
                android:textSize="12sp"
                android:textColor="@color/heirloom_on_surface"
                android:textStyle="bold"
                android:gravity="center"
                android:maxLines="1"
                android:ellipsize="end" />

            <!-- Relation -->
            <TextView
                android:id="@+id/tv_member_relation"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="1dp"
                android:textSize="10sp"
                android:textColor="@color/heirloom_on_surface_faint"
                android:gravity="center"
                android:maxLines="1"
                android:ellipsize="end" />

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

</LinearLayout>
