<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/heirloom_background"
    android:fitsSystemWindows="true">

    <!-- ===== COLLAPSING HERO ===== -->
    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/app_bar"
        android:layout_width="match_parent"
        android:layout_height="330dp"
        android:fitsSystemWindows="true"
        app:liftOnScroll="false">

        <com.google.android.material.appbar.CollapsingToolbarLayout
            android:id="@+id/collapsing_toolbar"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fitsSystemWindows="true"
            app:layout_scrollFlags="scroll|exitUntilCollapsed"
            app:contentScrim="@color/heirloom_primary">

            <!-- Hero photo -->
            <ImageView
                android:id="@+id/iv_profile_hero"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:fitsSystemWindows="true"
                android:contentDescription="@null"
                app:layout_collapseMode="parallax"
                app:layout_collapseParallaxMultiplier="0.7" />

            <!-- Gradient overlay -->
            <View
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/gradient_profile_hero"
                android:fitsSystemWindows="true"
                app:layout_collapseMode="pin" />

            <!-- Name + role overlay at bottom -->
            <LinearLayout
                android:id="@+id/profile_name_overlay"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom"
                android:orientation="vertical"
                android:paddingStart="22dp"
                android:paddingEnd="22dp"
                android:paddingBottom="18dp"
                app:layout_collapseMode="pin">

                <!-- Role badge pill -->
                <TextView
                    android:id="@+id/tv_role_badge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="GRANDMOTHER"
                    android:textSize="10sp"
                    android:textColor="@color/white"
                    android:textStyle="bold"
                    android:letterSpacing="0.08"
                    android:textAllCaps="true"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"
                    android:paddingTop="4dp"
                    android:paddingBottom="4dp"
                    android:background="@drawable/bg_role_badge" />

                <!-- Full name -->
                <TextView
                    android:id="@+id/tv_member_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="9dp"
                    android:text="Eleanor Hartwell"
                    android:textSize="30sp"
                    android:textColor="@color/white"
                    android:lineSpacingMultiplier="1.05" />

                <!-- Birth + location -->
                <TextView
                    android:id="@+id/tv_member_details"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="b. 1944  ·  Savannah, Georgia"
                    android:textSize="13sp"
                    android:textColor="@color/white"
                    android:alpha="0.92" />

            </LinearLayout>

            <!-- Back + overflow toolbar -->
            <androidx.appcompat.widget.Toolbar
                android:id="@+id/toolbar"
                android:layout_width="match_parent"
                android:layout_height="?attr/actionBarSize"
                app:layout_collapseMode="pin"
                app:navigationIcon="@drawable/ic_arrow_back"
                app:navigationIconTint="@color/white" />

        </com.google.android.material.appbar.CollapsingToolbarLayout>

    </com.google.android.material.appbar.AppBarLayout>

    <!-- ===== SCROLLABLE CONTENT ===== -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="24dp">

            <!-- Action buttons -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="16dp"
                android:weightSum="2">

                <Button
                    android:id="@+id/btn_message"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="5dp"
                    android:text="@string/profile_action_message"
                    android:textColor="@color/white"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:background="@drawable/bg_button_primary"
                    android:stateListAnimator="@null" />

                <Button
                    android:id="@+id/btn_add_memory"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:layout_marginStart="5dp"
                    android:text="@string/profile_action_add_memory"
                    android:textColor="@color/heirloom_on_surface_medium"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:background="@drawable/bg_button_secondary"
                    android:stateListAnimator="@null" />

            </LinearLayout>

            <!-- Quick facts grid (2x2) -->
            <androidx.gridlayout.widget.GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="18dp"
                android:layout_marginEnd="18dp"
                android:layout_marginTop="4dp"
                app:columnCount="2"
                app:useDefaultMargins="false">

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_margin="5dp"
                    app:cardBackgroundColor="@color/heirloom_surface"
                    app:cardCornerRadius="15dp"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/heirloom_border"
                    app:strokeWidth="1dp"
                    app:layout_columnWeight="1">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="vertical" android:padding="12dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="@string/profile_label_spouse" android:textSize="10sp"
                            android:textColor="@color/heirloom_on_surface_subtle"
                            android:textStyle="bold" android:textAllCaps="true" android:letterSpacing="0.05" />
                        <TextView android:id="@+id/tv_spouse" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:layout_marginTop="3dp"
                            android:text="Arthur Hartwell" android:textSize="14sp"
                            android:textColor="@color/heirloom_on_surface" android:textStyle="bold" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_margin="5dp"
                    app:cardBackgroundColor="@color/heirloom_surface"
                    app:cardCornerRadius="15dp"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/heirloom_border"
                    app:strokeWidth="1dp"
                    app:layout_columnWeight="1">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="vertical" android:padding="12dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="@string/profile_label_children" android:textSize="10sp"
                            android:textColor="@color/heirloom_on_surface_subtle"
                            android:textStyle="bold" android:textAllCaps="true" android:letterSpacing="0.05" />
                        <TextView android:id="@+id/tv_children" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:layout_marginTop="3dp"
                            android:text="3 · M, R, S" android:textSize="14sp"
                            android:textColor="@color/heirloom_on_surface" android:textStyle="bold" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_margin="5dp"
                    app:cardBackgroundColor="@color/heirloom_surface"
                    app:cardCornerRadius="15dp"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/heirloom_border"
                    app:strokeWidth="1dp"
                    app:layout_columnWeight="1">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="vertical" android:padding="12dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="@string/profile_label_grandchildren" android:textSize="10sp"
                            android:textColor="@color/heirloom_on_surface_subtle"
                            android:textStyle="bold" android:textAllCaps="true" android:letterSpacing="0.05" />
                        <TextView android:id="@+id/tv_grandchildren" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:layout_marginTop="3dp"
                            android:text="8" android:textSize="14sp"
                            android:textColor="@color/heirloom_on_surface" android:textStyle="bold" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_margin="5dp"
                    app:cardBackgroundColor="@color/heirloom_surface"
                    app:cardCornerRadius="15dp"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/heirloom_border"
                    app:strokeWidth="1dp"
                    app:layout_columnWeight="1">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="vertical" android:padding="12dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="@string/profile_label_maiden_name" android:textSize="10sp"
                            android:textColor="@color/heirloom_on_surface_subtle"
                            android:textStyle="bold" android:textAllCaps="true" android:letterSpacing="0.05" />
                        <TextView android:id="@+id/tv_maiden_name" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:layout_marginTop="3dp"
                            android:text="Whitfield" android:textSize="14sp"
                            android:textColor="@color/heirloom_on_surface" android:textStyle="bold" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

            </androidx.gridlayout.widget.GridLayout>

            <!-- Bio / About -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingTop="18dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/profile_about_title"
                    android:textSize="17sp"
                    android:textColor="@color/heirloom_on_surface"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/tv_bio"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="&quot;She raised three children on Magnolia Street, kept every recipe by hand, and never missed a Sunday supper. The heart of the Hartwells.&quot;"
                    android:textSize="15sp"
                    android:textColor="@color/heirloom_on_surface_medium"
                    android:textStyle="italic"
                    android:lineSpacingMultiplier="1.6" />

            </LinearLayout>

            <!-- Immediate family strip -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_marginTop="16dp"
                android:text="@string/profile_family_title"
                android:textSize="17sp"
                android:textColor="@color/heirloom_on_surface"
                android:textStyle="bold" />

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:paddingStart="20dp"
                android:scrollbars="none"
                android:clipToPadding="false">

                <LinearLayout
                    android:id="@+id/family_strip_container"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal" />

            </HorizontalScrollView>

            <!-- Photos section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingTop="14dp"
                android:paddingBottom="12dp"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/profile_photos_title"
                    android:textSize="17sp"
                    android:textColor="@color/heirloom_on_surface"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/btn_see_all_photos"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="See all 42"
                    android:textSize="12sp"
                    android:textColor="@color/heirloom_primary"
                    android:textStyle="bold"
                    android:clickable="true"
                    android:focusable="true" />

            </LinearLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_profile_photos"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:clipToPadding="false"
                android:nestedScrollingEnabled="false" />

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
