<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/heirloom_background"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="@dimen/screen_horizontal_padding"
        android:paddingEnd="@dimen/screen_horizontal_padding"
        android:paddingTop="@dimen/status_bar_approx"
        android:paddingBottom="@dimen/space_30">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_12"
            android:layout_marginBottom="@dimen/space_18"
            android:text="@string/my_profile_title"
            android:textAppearance="@style/TextAppearance.Heirloom.TitleLarge" />

        <!-- Hero card -->
        <com.google.android.material.card.MaterialCardView
            style="@style/Widget.Heirloom.Card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="@dimen/space_16">

                <FrameLayout
                    android:layout_width="@dimen/avatar_xl"
                    android:layout_height="@dimen/avatar_xl">

                    <ImageView
                        android:id="@+id/iv_my_avatar"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/bg_avatar_circle" />

                    <TextView
                        android:id="@+id/tv_my_initial"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:textColor="@color/white"
                        android:textSize="@dimen/text_title_lg"
                        tools:text="A" />
                </FrameLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="@dimen/space_14"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tv_my_name"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textAppearance="@style/TextAppearance.Heirloom.TitleMedium"
                        tools:text="Alok Singh" />

                    <TextView
                        android:id="@+id/tv_my_role"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_4"
                        android:textAppearance="@style/TextAppearance.Heirloom.BodySmall"
                        tools:text="You · Family member" />
                </LinearLayout>

                <ImageView
                    android:id="@+id/btn_edit_profile_icon"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:padding="2dp"
                    app:tint="@color/heirloom_on_surface_subtle"
                    android:src="@drawable/ic_chevron_right" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Account -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_24"
            android:layout_marginBottom="@dimen/space_10"
            android:text="@string/my_profile_section_account"
            android:textAppearance="@style/TextAppearance.Heirloom.Label" />

        <com.google.android.material.card.MaterialCardView
            style="@style/Widget.Heirloom.Card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <LinearLayout
                android:id="@+id/container_account_rows"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />
        </com.google.android.material.card.MaterialCardView>

        <!-- Family -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_20"
            android:layout_marginBottom="@dimen/space_10"
            android:text="@string/my_profile_section_family"
            android:textAppearance="@style/TextAppearance.Heirloom.Label" />

        <com.google.android.material.card.MaterialCardView
            style="@style/Widget.Heirloom.Card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <LinearLayout
                android:id="@+id/container_family_rows"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />
        </com.google.android.material.card.MaterialCardView>

        <!-- About -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_20"
            android:layout_marginBottom="@dimen/space_10"
            android:text="@string/my_profile_section_about"
            android:textAppearance="@style/TextAppearance.Heirloom.Label" />

        <com.google.android.material.card.MaterialCardView
            style="@style/Widget.Heirloom.Card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <LinearLayout
                android:id="@+id/container_about_rows"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:id="@+id/tv_sign_out"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_24"
            android:background="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:padding="@dimen/space_14"
            android:text="@string/my_profile_sign_out"
            android:textAppearance="@style/TextAppearance.Heirloom.Body"
            android:textColor="@color/heirloom_destructive" />

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
