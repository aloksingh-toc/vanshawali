<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/heirloom_background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="24dp">

        <!-- ===== TOP BAR ===== -->
        <LinearLayout
            android:id="@+id/top_bar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="22dp"
            android:paddingEnd="22dp"
            android:paddingTop="12dp"
            android:paddingBottom="16dp"
            android:gravity="center_vertical">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tv_greeting"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/home_greeting_prefix"
                    android:textSize="12sp"
                    android:textColor="@color/heirloom_on_surface_faint"
                    android:textStyle="bold"
                    android:letterSpacing="0.07"
                    android:textAllCaps="true" />

                <TextView
                    android:id="@+id/tv_family_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="The Hartwell Family"
                    android:textSize="27sp"
                    android:textColor="@color/heirloom_on_surface"
                    android:lineSpacingMultiplier="1.12" />

            </LinearLayout>

            <!-- Bell notification button -->
            <FrameLayout
                android:id="@+id/btn_notifications"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="@drawable/bg_circle_surface"
                android:clickable="true"
                android:focusable="true">

                <ImageView
                    android:layout_width="21dp"
                    android:layout_height="21dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_bell"
                    android:contentDescription="@string/cd_notification_bell"
                    app:tint="@color/heirloom_on_surface_medium" />

                <!-- Unread dot -->
                <View
                    android:id="@+id/notification_dot"
                    android:layout_width="9dp"
                    android:layout_height="9dp"
                    android:layout_gravity="top|end"
                    android:layout_marginTop="9dp"
                    android:layout_marginEnd="9dp"
                    android:background="@drawable/bg_unread_dot"
                    android:visibility="visible" />

            </FrameLayout>

        </LinearLayout>

        <!-- ===== BIRTHDAY HERO CARD ===== -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_birthday"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="18dp"
            android:layout_marginEnd="18dp"
            app:cardBackgroundColor="@color/heirloom_primary"
            app:cardCornerRadius="24dp"
            app:cardElevation="0dp"
            app:strokeWidth="0dp">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="19dp">

                <!-- Decorative circles -->
                <View
                    android:layout_width="128dp"
                    android:layout_height="128dp"
                    android:layout_gravity="top|end"
                    android:layout_marginTop="-34dp"
                    android:layout_marginEnd="-34dp"
                    android:background="@drawable/bg_circle_white_08"
                    android:clickable="false" />

                <View
                    android:layout_width="74dp"
                    android:layout_height="74dp"
                    android:layout_gravity="bottom|end"
                    android:layout_marginBottom="-30dp"
                    android:layout_marginEnd="18dp"
                    android:background="@drawable/bg_circle_white_06"
                    android:clickable="false" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- Label row -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:alpha="0.9">

                        <ImageView
                            android:layout_width="15dp"
                            android:layout_height="15dp"
                            android:src="@drawable/ic_gift"
                            app:tint="@color/white"
                            android:layout_marginEnd="7dp"
                            android:contentDescription="@null" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/home_upcoming_birthday"
                            android:textSize="11sp"
                            android:textColor="@color/white"
                            android:textStyle="bold"
                            android:letterSpacing="0.1"
                            android:textAllCaps="true" />

                    </LinearLayout>

                    <!-- Person row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="15dp"
                        android:gravity="center_vertical">

                        <!-- Avatar -->
                        <FrameLayout
                            android:layout_width="58dp"
                            android:layout_height="58dp"
                            android:layout_marginEnd="14dp">

                            <ImageView
                                android:id="@+id/iv_birthday_avatar"
                                android:layout_width="58dp"
                                android:layout_height="58dp"
                                android:background="@drawable/bg_birthday_avatar"
                                android:scaleType="centerCrop" />

                            <TextView
                                android:id="@+id/tv_birthday_initial"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center"
                                android:text="E"
                                android:textSize="24sp"
                                android:textColor="@color/white"
                                android:textStyle="bold" />

                        </FrameLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/tv_birthday_name"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Grandma Eleanor"
                                android:textSize="21sp"
                                android:textColor="@color/white"
                                android:lineSpacingMultiplier="1.1" />

                            <TextView
                                android:id="@+id/tv_birthday_subtitle"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="3dp"
                                android:text="turns 82 · in 3 days"
                                android:textSize="13sp"
                                android:textColor="@color/white"
                                android:alpha="0.9" />

                        </LinearLayout>

                    </LinearLayout>

                    <!-- CTA Button -->
                    <Button
                        android:id="@+id/btn_birthday_wish"
                        android:layout_width="match_parent"
                        android:layout_height="44dp"
                        android:layout_marginTop="17dp"
                        android:text="@string/home_birthday_cta"
                        android:textColor="@color/heirloom_primary_dark"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:background="@drawable/bg_button_cream"
                        android:stateListAnimator="@null" />

                </LinearLayout>
            </FrameLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- ===== STATS ROW ===== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginStart="18dp"
            android:layout_marginEnd="18dp"
            android:layout_marginTop="18dp"
            android:weightSum="3">

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_stat_members"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="5.5dp"
                app:cardBackgroundColor="@color/heirloom_surface"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/heirloom_border"
                app:strokeWidth="1dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="13dp">
                    <TextView android:id="@+id/tv_stat_members" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text="28" android:textSize="23sp"
                        android:textColor="@color/heirloom_on_surface" android:textStyle="bold" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="@string/home_stat_members" android:textSize="11sp"
                        android:textColor="@color/heirloom_on_surface_faint" android:textStyle="bold"
                        android:layout_marginTop="1dp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_stat_generations"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="5.5dp"
                android:layout_marginEnd="5.5dp"
                app:cardBackgroundColor="@color/heirloom_surface"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/heirloom_border"
                app:strokeWidth="1dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="13dp">
                    <TextView android:id="@+id/tv_stat_generations" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text="4" android:textSize="23sp"
                        android:textColor="@color/heirloom_on_surface" android:textStyle="bold" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="@string/home_stat_generations" android:textSize="11sp"
                        android:textColor="@color/heirloom_on_surface_faint" android:textStyle="bold"
                        android:layout_marginTop="1dp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_stat_photos"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="5.5dp"
                app:cardBackgroundColor="@color/heirloom_surface"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/heirloom_border"
                app:strokeWidth="1dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="13dp">
                    <TextView android:id="@+id/tv_stat_photos" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text="214" android:textSize="23sp"
                        android:textColor="@color/heirloom_on_surface" android:textStyle="bold" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="@string/home_stat_photos" android:textSize="11sp"
                        android:textColor="@color/heirloom_on_surface_faint" android:textStyle="bold"
                        android:layout_marginTop="1dp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

        <!-- ===== YOUR TREE SECTION ===== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="22dp"
            android:paddingEnd="22dp"
            android:paddingTop="20dp"
            android:paddingBottom="10dp"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/home_your_tree"
                android:textSize="18sp"
                android:textColor="@color/heirloom_on_surface"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/btn_open_tree"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/home_open_tree"
                android:textSize="13sp"
                android:textColor="@color/heirloom_primary"
                android:textStyle="bold"
                android:clickable="true"
                android:focusable="true" />

        </LinearLayout>

        <!-- Mini tree preview (custom view) -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_tree_preview"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="18dp"
            android:layout_marginEnd="18dp"
            android:clickable="true"
            android:focusable="true"
            app:cardBackgroundColor="@color/heirloom_surface"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/heirloom_border"
            app:strokeWidth="1dp">

            <com.meragaw.vanshawali.ui.view.MiniTreeView
                android:id="@+id/mini_tree_view"
                android:layout_width="match_parent"
                android:layout_height="160dp"
                android:padding="16dp" />

        </com.google.android.material.card.MaterialCardView>

        <!-- ===== RECENTLY ADDED ===== -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="22dp"
            android:layout_marginTop="22dp"
            android:text="@string/home_recently_added"
            android:textSize="18sp"
            android:textColor="@color/heirloom_on_surface"
            android:textStyle="bold" />

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:paddingStart="18dp"
            android:paddingEnd="18dp"
            android:scrollbars="none"
            android:clipToPadding="false">

            <LinearLayout
                android:id="@+id/recently_added_container"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal" />

        </HorizontalScrollView>

        <!-- ===== ON THIS DAY ===== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="22dp"
            android:paddingEnd="22dp"
            android:paddingTop="22dp"
            android:paddingBottom="12dp"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/home_on_this_day"
                android:textSize="18sp"
                android:textColor="@color/heirloom_on_surface"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_memory_year"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="2019"
                android:textSize="12sp"
                android:textColor="@color/heirloom_on_surface_faint"
                android:textStyle="bold" />

        </LinearLayout>

        <!-- 2-column memory grid -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="18dp"
            android:paddingEnd="18dp">

            <ImageView
                android:id="@+id/iv_memory_main"
                android:layout_width="0dp"
                android:layout_height="140dp"
                android:layout_weight="1"
                android:layout_marginEnd="5dp"
                android:scaleType="centerCrop"
                android:background="@drawable/bg_photo_placeholder"
                android:contentDescription="@null" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="140dp"
                android:layout_weight="1"
                android:layout_marginStart="5dp"
                android:orientation="vertical">

                <ImageView
                    android:id="@+id/iv_memory_top"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:layout_marginBottom="5dp"
                    android:scaleType="centerCrop"
                    android:background="@drawable/bg_photo_placeholder"
                    android:contentDescription="@null" />

                <ImageView
                    android:id="@+id/iv_memory_bottom"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:layout_marginTop="5dp"
                    android:scaleType="centerCrop"
                    android:background="@drawable/bg_photo_placeholder"
                    android:contentDescription="@null" />

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

</androidx.core.widget.NestedScrollView>
