<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/heirloom_background">

    <!-- ===== HEADER ===== -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="12dp"
        android:paddingBottom="14dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/search_title"
            android:textSize="23sp"
            android:textColor="@color/heirloom_on_surface"
            android:textStyle="bold"
            android:layout_marginBottom="14dp" />

        <!-- Search TextInputLayout -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/search_field_layout"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:hint="@string/search_hint"
            style="@style/Widget.Heirloom.SearchField"
            app:startIconDrawable="@drawable/ic_search"
            app:startIconTint="@color/heirloom_primary"
            app:endIconMode="clear_text"
            app:endIconTint="@color/heirloom_on_surface_faint">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_search"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:textSize="15sp"
                android:textColor="@color/heirloom_on_surface"
                android:inputType="textPersonName"
                android:imeOptions="actionSearch"
                android:singleLine="true" />

        </com.google.android.material.textfield.TextInputLayout>

    </LinearLayout>

    <!-- ===== FILTER CHIPS ===== -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingBottom="14dp"
        android:scrollbars="none"
        android:clipToPadding="false">

        <com.google.android.material.chip.ChipGroup
            android:id="@+id/chip_group_search_filter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:singleSelection="true"
            app:selectionRequired="true">

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_filter_all"
                style="@style/Widget.Heirloom.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/search_filter_all"
                android:checked="true" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_filter_living"
                style="@style/Widget.Heirloom.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/search_filter_living" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_filter_gen2"
                style="@style/Widget.Heirloom.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/search_filter_gen2" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_filter_surname"
                style="@style/Widget.Heirloom.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/search_filter_surname" />

        </com.google.android.material.chip.ChipGroup>

    </HorizontalScrollView>

    <!-- ===== RESULTS COUNT ===== -->
    <TextView
        android:id="@+id/tv_results_count"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="20dp"
        android:layout_marginBottom="6dp"
        android:text="6 RESULTS"
        android:textSize="11sp"
        android:textColor="@color/heirloom_on_surface_subtle"
        android:textStyle="bold"
        android:letterSpacing="0.06"
        android:textAllCaps="true"
        android:visibility="gone" />

    <!-- ===== RESULTS LIST ===== -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_search_results"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false" />

    <!-- ===== EMPTY STATE ===== -->
    <LinearLayout
        android:id="@+id/empty_state"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:visibility="gone">

        <ImageView
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:src="@drawable/ic_search"
            android:alpha="0.3"
            app:tint="@color/heirloom_on_surface_faint"
            android:contentDescription="@null" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="No members found"
            android:textSize="16sp"
            android:textColor="@color/heirloom_on_surface_faint"
            android:textStyle="bold" />

    </LinearLayout>

</LinearLayout>
