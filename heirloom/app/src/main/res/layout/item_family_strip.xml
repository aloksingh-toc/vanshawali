<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:layout_marginEnd="16dp"
    android:orientation="vertical"
    android:gravity="center_horizontal"
    android:clickable="true"
    android:focusable="true">

    <FrameLayout
        android:layout_width="@dimen/avatar_lg"
        android:layout_height="@dimen/avatar_lg">

        <ImageView
            android:id="@+id/iv_strip_avatar"
            android:layout_width="@dimen/avatar_lg"
            android:layout_height="@dimen/avatar_lg"
            android:scaleType="centerCrop"
            android:background="@drawable/bg_avatar_circle"
            android:contentDescription="@null" />

        <TextView
            android:id="@+id/tv_strip_initial"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:textSize="20sp"
            android:textColor="@color/white"
            android:textStyle="bold" />

    </FrameLayout>

    <TextView
        android:id="@+id/tv_strip_name"
        android:layout_width="64dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="7dp"
        android:textSize="12sp"
        android:textColor="@color/heirloom_on_surface"
        android:textStyle="bold"
        android:gravity="center"
        android:maxLines="1"
        android:ellipsize="end" />

    <TextView
        android:id="@+id/tv_strip_role"
        android:layout_width="64dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="1dp"
        android:textSize="10sp"
        android:textColor="@color/heirloom_on_surface_faint"
        android:gravity="center"
        android:maxLines="1"
        android:ellipsize="end" />

</LinearLayout>
