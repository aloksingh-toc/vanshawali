<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <!-- Section label (TODAY / EARLIER) — shown for first item in section -->
    <TextView
        android:id="@+id/tv_section_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="20dp"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="8dp"
        android:textSize="11sp"
        android:textColor="@color/heirloom_on_surface_subtle"
        android:textStyle="bold"
        android:letterSpacing="0.08"
        android:textAllCaps="true"
        android:visibility="gone" />

    <!-- Highlighted notification card (unread) -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/card_highlighted"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="12dp"
        android:layout_marginBottom="8dp"
        android:visibility="gone"
        app:cardBackgroundColor="@color/heirloom_birthday_bg"
        app:cardCornerRadius="16dp"
        app:cardElevation="0dp"
        app:strokeColor="@color/heirloom_birthday_border"
        app:strokeWidth="1dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="12dp"
            android:gravity="top">

            <!-- Icon container -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_icon"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_marginEnd="13dp"
                app:cardBackgroundColor="@color/heirloom_primary"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                app:strokeWidth="0dp">
                <ImageView
                    android:id="@+id/iv_notif_icon"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_gift"
                    android:contentDescription="@null"
                    app:tint="@color/white" />
            </com.google.android.material.card.MaterialCardView>

            <!-- Message -->
            <TextView
                android:id="@+id/tv_message_highlighted"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textSize="13.5sp"
                android:textColor="@color/heirloom_on_surface"
                android:lineSpacingMultiplier="1.4" />

            <!-- Unread dot -->
            <View
                android:id="@+id/unread_dot"
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:layout_marginStart="8dp"
                android:layout_marginTop="4dp"
                android:background="@drawable/bg_unread_dot_small"
                android:visibility="gone" />

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

    <!-- Standard activity row (read) -->
    <LinearLayout
        android:id="@+id/row_activity"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="12dp"
        android:paddingBottom="12dp"
        android:gravity="top"
        android:visibility="gone">

        <!-- Avatar -->
        <FrameLayout
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_marginEnd="13dp">

            <ImageView
                android:id="@+id/iv_activity_avatar"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:scaleType="centerCrop"
                android:background="@drawable/bg_avatar_circle"
                android:contentDescription="@null" />

            <TextView
                android:id="@+id/tv_activity_initial"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:textSize="18sp"
                android:textColor="@color/white"
                android:textStyle="bold" />

        </FrameLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_activity_message"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="13.5sp"
                android:textColor="@color/heirloom_on_surface_medium"
                android:lineSpacingMultiplier="1.4" />

            <TextView
                android:id="@+id/tv_activity_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textSize="11sp"
                android:textColor="@color/heirloom_on_surface_faint" />

        </LinearLayout>

    </LinearLayout>

</LinearLayout>
